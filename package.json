{
  "name": "@yriveiro/inktty",
  "version": "1.0.0",
  "type": "module",
  "description": "A simple terminal markdown reader built with OpenTUI",
  "author": "yriveiro",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yriveiro/inktty.git"
  },
  "homepage": "https://github.com/yriveiro/inktty#readme",
  "bugs": {
    "url": "https://github.com/yriveiro/inktty/issues"
  },
  "keywords": [
    "terminal",
    "markdown",
    "tui",
    "opentui",
    "reader"
  ],
  "bin": {
    "ink": "./bin/ink.tsx"
  },
  "scripts": {
    "start": "bun run bin/ink.tsx",
    "dev": "bun --watch run bin/ink.tsx",
    "test": "bun test",
    "test:bdd": "bun test tests/bdd",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf bun.lock",
    "prepublishOnly": "bun run typecheck && bun run lint",
    "prepack": "bun run typecheck && bun run lint"
  },
  "dependencies": {
    "@opentui/core": "0.2.0",
    "@opentui/react": "0.2.0",
    "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.1",
    "beautiful-mermaid": "^1.1.3",
    "marked": "18.0.2",
    "react": "19.2.5",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-json": "^0.24.8",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/bun": "1.3.13",
    "@types/react": "19.2.14",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
